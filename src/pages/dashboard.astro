---
import Navbar from '../components/Navbar.astro';
import { getSessionUser } from '../server/auth/session';

const db = Astro.locals.runtime.env.DB;
const token = Astro.cookies.get('session')?.value;
const user = token ? await getSessionUser(db, token) : null;

if (!user) {
  return Astro.redirect('/login');
}
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard — Rekan Siber</title>
  </head>
  <body>
    <Navbar user={user} />
    <main>
      <h1>Dashboard</h1>
      <p>Selamat datang, {user.full_name} ({user.role}).</p>
      <p>Statistik penggunaan IOC checker per anggota tim akan tampil di sini (tahap coding berikutnya).</p>
    </main>
  </body>
</html>
