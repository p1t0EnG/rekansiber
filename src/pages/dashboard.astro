---
import Navbar from '../components/Navbar.astro';
import { getSessionUser } from '../server/auth/session';
import { getDashboardStats } from '../server/dashboard/stats';

const db = Astro.locals.runtime.env.DB;
const token = Astro.cookies.get('session')?.value;
const user = token ? await getSessionUser(db, token) : null;

if (!user) {
  return Astro.redirect('/login');
}

const { summary, daily } = await getDashboardStats(db);
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard — Rekan Siber</title>
  </head>
  <body>
    <Navbar user={user} />
    <main>
      <h1>Dashboard</h1>
      <p>Selamat datang, {user.full_name} ({user.role}).</p>

      <h2>Ringkasan per Anggota</h2>
      <table>
        <thead>
          <tr>
            <th>Nama</th>
            <th>Total Cek</th>
            <th>Malicious</th>
            <th>Suspicious</th>
            <th>Clean</th>
          </tr>
        </thead>
        <tbody>
          {summary.map((s) => (
            <tr>
              <td>{s.full_name}</td>
              <td>{s.total_checks}</td>
              <td>{s.malicious_count}</td>
              <td>{s.suspicious_count}</td>
              <td>{s.clean_count}</td>
            </tr>
          ))}
          {summary.length === 0 && (
            <tr>
              <td colspan="5">Belum ada data pengecekan dari tim SOC.</td>
            </tr>
          )}
        </tbody>
      </table>

      <h2>Aktivitas 30 Hari Terakhir</h2>
      <table>
        <thead>
          <tr>
            <th>Tanggal</th>
            <th>Nama</th>
            <th>Jumlah Cek</th>
          </tr>
        </thead>
        <tbody>
          {daily.map((d) => (
            <tr>
              <td>{d.day}</td>
              <td>{d.full_name}</td>
              <td>{d.count}</td>
            </tr>
          ))}
          {daily.length === 0 && (
            <tr>
              <td colspan="3">Belum ada aktivitas 30 hari terakhir.</td>
            </tr>
          )}
        </tbody>
      </table>
    </main>

    <style>
      table {
        border-collapse: collapse;
        width: 100%;
        max-width: 700px;
        margin-bottom: 2rem;
      }
      th,
      td {
        text-align: left;
        padding: 0.5rem;
        border-bottom: 1px solid #2a2f3a;
      }
    </style>
  </body>
</html>
