---
import Layout from '../layouts/Layout.astro';
import { getSessionUser } from '../server/auth/session';
import { getDashboardStats } from '../server/dashboard/stats';

const db = Astro.locals.runtime.env.DB;
const token = Astro.cookies.get('session')?.value;
const user = token ? await getSessionUser(db, token) : null;

if (!user) {
  return Astro.redirect('/login');
}

const { summary, daily } = await getDashboardStats(db);

const totals = summary.reduce(
  (acc, s) => ({
    checks: acc.checks + s.total_checks,
    malicious: acc.malicious + s.malicious_count,
    suspicious: acc.suspicious + s.suspicious_count,
    clean: acc.clean + s.clean_count,
  }),
  { checks: 0, malicious: 0, suspicious: 0, clean: 0 },
);
---

<Layout title="Dashboard" user={user}>
  <div class="page-header">
    <h1>Dashboard</h1>
    <p>Selamat datang, {user.full_name} ({user.role}).</p>
  </div>

  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-value">{totals.checks}</div>
      <div class="stat-label">Total Pengecekan</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: var(--danger);">{totals.malicious}</div>
      <div class="stat-label">Malicious</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: var(--warning);">{totals.suspicious}</div>
      <div class="stat-label">Suspicious</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: var(--success);">{totals.clean}</div>
      <div class="stat-label">Clean</div>
    </div>
  </div>

  <div class="card">
    <h2>Ringkasan per Anggota</h2>
    <table>
      <thead>
        <tr>
          <th>Nama</th>
          <th>Total Cek</th>
          <th>Malicious</th>
          <th>Suspicious</th>
          <th>Clean</th>
        </tr>
      </thead>
      <tbody>
        {summary.map((s) => (
          <tr>
            <td>{s.full_name}</td>
            <td>{s.total_checks}</td>
            <td>{s.malicious_count}</td>
            <td>{s.suspicious_count}</td>
            <td>{s.clean_count}</td>
          </tr>
        ))}
      </tbody>
    </table>
    {summary.length === 0 && <p class="empty-state">Belum ada data pengecekan dari tim SOC.</p>}
  </div>

  <div class="card">
    <h2>Aktivitas 30 Hari Terakhir</h2>
    <table>
      <thead>
        <tr>
          <th>Tanggal</th>
          <th>Nama</th>
          <th>Jumlah Cek</th>
        </tr>
      </thead>
      <tbody>
        {daily.map((d) => (
          <tr>
            <td>{d.day}</td>
            <td>{d.full_name}</td>
            <td>{d.count}</td>
          </tr>
        ))}
      </tbody>
    </table>
    {daily.length === 0 && <p class="empty-state">Belum ada aktivitas 30 hari terakhir.</p>}
  </div>
</Layout>
