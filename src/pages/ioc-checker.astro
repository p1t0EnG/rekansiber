---
import Layout from '../layouts/Layout.astro';
import AppLayout from '../layouts/AppLayout.astro';
import IocToolsTabs from '../components/IocToolsTabs.astro';
import { getSessionUser } from '../server/auth/session';

const db = Astro.locals.runtime.env.DB;
const token = Astro.cookies.get('session')?.value;
const user = token ? await getSessionUser(db, token) : null;
const PageLayout = user ? AppLayout : Layout;
---

<PageLayout title="IOC Checker" user={user}>
  <div class="page-header">
    <h1>IOC Tools</h1>
    <p>Cek reputasi IOC satu per satu, secara massal, atau ekstrak dari dokumen -- pilih mode di bawah.</p>
  </div>

  <IocToolsTabs current="single" user={user} />

  <div class="page-header">
    <h2 style="font-size:1.15rem;">Cek Satuan</h2>
    <p>Masukkan satu IP, domain, hash, URL, atau alamat email.</p>
  </div>

  <div class="card">
    <form id="ioc-form">
      <div class="field">
        <label for="ioc-value">Value</label>
        <div class="input-row">
          <input id="ioc-value" name="value" type="text" placeholder="Contoh: 8.8.8.8 atau google.com atau https://google.com atau 44d88612fea8a8f36de82e1278abb02f atau nama@domain.com" required autocomplete="off" />
          <span id="ioc-type-badge" class="badge" style="display:none;"></span>
        </div>
      </div>
      <button type="submit" class="btn" id="ioc-submit">Cek Sekarang</button>
    </form>
  </div>

  <p id="result-error" class="status-message" data-tone="error" role="alert"></p>

  <div id="result-summary" class="card" style="display:none;">
    <div class="result-head">
      <code id="result-value"></code>
      <span id="result-verdict" class="badge"></span>
    </div>
  </div>

  <div id="result-providers" class="provider-grid"></div>

  {/* is:global karena card provider dibuat dinamis (document.createElement) --
      style scoped Astro tidak menempel ke elemen buatan script. */}
  <style is:global>
    .input-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .input-row input {
      flex: 1;
      min-width: 200px;
    }
    .result-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .result-head code {
      font-family: var(--font-mono);
      font-size: 0.95rem;
      word-break: break-all;
    }
    .provider-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }
    .provider-card {
      margin-bottom: 0;
    }
    .provider-card-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      margin-bottom: 0.6rem;
    }
    .provider-card-head strong {
      font-size: 0.95rem;
    }
    .provider-detail {
      color: var(--text-muted);
      font-size: 0.86rem;
      margin: 0 0 1.1rem;
    }
    .provider-link {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--brand);
      text-decoration: none;
    }
    .provider-link:hover {
      text-decoration: underline;
    }
  </style>

  <script>
    import { detectIocType } from '../server/ioc/validate';

    interface ProviderResult {
      name: string;
      verdict: string;
      detail: string;
    }
    interface IocCheckResult {
      value: string;
      type: string;
      verdict: string;
      providers: ProviderResult[];
      error?: string;
    }

    const form = document.getElementById('ioc-form') as HTMLFormElement;
    const submitBtn = document.getElementById('ioc-submit') as HTMLButtonElement;
    const valueInput = document.getElementById('ioc-value') as HTMLInputElement;
    const typeBadge = document.getElementById('ioc-type-badge') as HTMLSpanElement;
    const errorEl = document.getElementById('result-error')!;
    const resultSummary = document.getElementById('result-summary') as HTMLDivElement;
    const resultValueEl = document.getElementById('result-value')!;
    const resultVerdictEl = document.getElementById('result-verdict') as HTMLSpanElement;
    const resultProvidersEl = document.getElementById('result-providers')!;

    // Link ke halaman pengecekan resmi tiap provider, biar analyst bisa lihat detail lengkap.
    // Untuk email, VT/OTX/MXToolbox mengecek DOMAIN-nya (bagian setelah '@').
    function buildProviderLink(providerName: string, type: string, value: string): string | null {
      const lookup = type === 'email' ? (value.split('@')[1] ?? '') : value;
      const encoded = encodeURIComponent(lookup);
      if (providerName === 'VirusTotal') {
        if (type === 'ip') return `https://www.virustotal.com/gui/ip-address/${encoded}`;
        if (type === 'domain' || type === 'email') return `https://www.virustotal.com/gui/domain/${encoded}`;
        if (type === 'hash') return `https://www.virustotal.com/gui/file/${encoded}`;
        if (type === 'url') return `https://www.virustotal.com/gui/search/${encoded}`;
      }
      if (providerName === 'AbuseIPDB') {
        if (type === 'ip') return `https://www.abuseipdb.com/check/${encoded}`;
      }
      if (providerName === 'OTX') {
        if (type === 'ip') return `https://otx.alienvault.com/indicator/ip/${encoded}`;
        if (type === 'domain' || type === 'email') return `https://otx.alienvault.com/indicator/domain/${encoded}`;
        if (type === 'hash') return `https://otx.alienvault.com/indicator/file/${encoded}`;
        if (type === 'url') return `https://otx.alienvault.com/indicator/url/${encoded}`;
      }
      if (providerName === 'MXToolbox') {
        if (type === 'email') return `https://mxtoolbox.com/SuperTool.aspx?action=blacklist%3a${encoded}&run=toolpage`;
      }
      return null;
    }

    const TYPE_LABEL: Record<string, string> = {
      ip: 'IP Address',
      domain: 'Domain',
      hash: 'File Hash',
      url: 'URL',
      email: 'Email',
    };

    valueInput.addEventListener('input', () => {
      const type = detectIocType(valueInput.value);
      if (type) {
        typeBadge.textContent = TYPE_LABEL[type];
        typeBadge.className = 'badge badge-unknown';
        typeBadge.style.display = 'inline-flex';
      } else {
        typeBadge.style.display = 'none';
      }
    });

    function renderResult(data: IocCheckResult) {
      resultValueEl.textContent = data.value;
      resultVerdictEl.textContent = data.verdict;
      resultVerdictEl.className = `badge badge-${data.verdict}`;

      resultProvidersEl.innerHTML = '';
      for (const p of data.providers) {
        const card = document.createElement('div');
        card.className = 'card provider-card';

        const head = document.createElement('div');
        head.className = 'provider-card-head';

        const name = document.createElement('strong');
        name.textContent = p.name;

        const badge = document.createElement('span');
        badge.className = `badge badge-${p.verdict}`;
        badge.textContent = p.verdict;

        head.appendChild(name);
        head.appendChild(badge);

        const detail = document.createElement('p');
        detail.className = 'provider-detail';
        detail.textContent = p.detail;

        card.appendChild(head);
        card.appendChild(detail);

        const link = buildProviderLink(p.name, data.type, data.value);
        if (link) {
          const a = document.createElement('a');
          a.href = link;
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.className = 'provider-link';
          a.textContent = `Lihat di ${p.name} →`;
          card.appendChild(a);
        }

        resultProvidersEl.appendChild(card);
      }

      resultSummary.style.display = 'block';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.textContent = '';
      resultSummary.style.display = 'none';
      resultProvidersEl.innerHTML = '';

      const value = valueInput.value;
      const type = detectIocType(value);

      if (!type) {
        errorEl.textContent = 'Format tidak dikenali. Masukkan IP, domain, hash (MD5/SHA1/SHA256), URL, atau alamat email yang valid.';
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Memeriksa...';

      try {
        const res = await fetch('/api/ioc/check', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type, value }),
        });
        const data = (await res.json()) as IocCheckResult;

        if (!res.ok) {
          errorEl.textContent = data.error ?? 'Gagal memeriksa IOC';
          return;
        }

        renderResult(data);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Cek Sekarang';
      }
    });
  </script>
</PageLayout>
