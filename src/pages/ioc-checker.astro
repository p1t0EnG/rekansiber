---
import Navbar from '../components/Navbar.astro';
import { getSessionUser } from '../server/auth/session';

const db = Astro.locals.runtime.env.DB;
const token = Astro.cookies.get('session')?.value;
const user = token ? await getSessionUser(db, token) : null;
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>IOC Checker — Rekan Siber</title>
  </head>
  <body>
    <Navbar user={user} />
    <main>
      <h1>IOC Checker</h1>
      <p>
        Masukkan IP, domain, hash, atau URL -- type-nya otomatis terdeteksi, lalu dicek ke
        VirusTotal, AbuseIPDB, dan OTX.
      </p>

      <form id="ioc-form">
        <input id="ioc-value" name="value" type="text" placeholder="Contoh: 8.8.8.8" required autocomplete="off" />
        <span id="ioc-type-badge"></span>
        <button type="submit">Cek Sekarang</button>
      </form>

      <pre id="result"></pre>
    </main>

    <script>
      import { detectIocType } from '../server/ioc/validate';

      const form = document.getElementById('ioc-form') as HTMLFormElement;
      const valueInput = document.getElementById('ioc-value') as HTMLInputElement;
      const typeBadge = document.getElementById('ioc-type-badge')!;
      const resultEl = document.getElementById('result')!;

      const TYPE_LABEL: Record<string, string> = {
        ip: 'IP Address',
        domain: 'Domain',
        hash: 'File Hash',
        url: 'URL',
      };

      valueInput.addEventListener('input', () => {
        const type = detectIocType(valueInput.value);
        typeBadge.textContent = type ? `Terdeteksi: ${TYPE_LABEL[type]}` : '';
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const value = valueInput.value;
        const type = detectIocType(value);

        if (!type) {
          resultEl.textContent = 'Format tidak dikenali. Masukkan IP, domain, hash (MD5/SHA1/SHA256), atau URL yang valid.';
          return;
        }

        resultEl.textContent = 'Memeriksa...';
        const res = await fetch('/api/ioc/check', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type, value }),
        });
        const data = await res.json();
        resultEl.textContent = JSON.stringify(data, null, 2);
      });
    </script>
  </body>
</html>
