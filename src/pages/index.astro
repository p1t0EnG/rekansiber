---
import Layout from '../layouts/Layout.astro';
import AppLayout from '../layouts/AppLayout.astro';
import { getSessionUser } from '../server/auth/session';

const db = Astro.locals.runtime.env.DB;
const token = Astro.cookies.get('session')?.value;
const user = token ? await getSessionUser(db, token) : null;
const PageLayout = user ? AppLayout : Layout;
---

<PageLayout title="Home" user={user}>
  <section class="hero card">
    <span class="eyebrow">Rekan Siber</span>
    <h1>Proactive Cyber Defense untuk Tim Kamu</h1>
    <p class="lead">
      Cek reputasi IP, domain, hash, dan URL dalam hitungan detik -- gratis dan terbuka untuk
      publik.
    </p>
    <div class="btn-row">
      <a href="/ioc-checker" class="btn">Mulai cek IOC →</a>
      <a href="/news" class="btn btn-secondary">Lihat berita terbaru</a>
    </div>
  </section>

  <div class="feature-grid">
    <a href="/ioc-checker" class="card feature-card">
      <h2>IOC Checker</h2>
      <p>Validasi IP, domain, hash, dan URL lewat VirusTotal, AbuseIPDB, dan OTX sekaligus.</p>
    </a>
    <a href="/news" class="card feature-card">
      <h2>Berita CVE &amp; Ransomware</h2>
      <p>Update otomatis tiap 6 jam dari The Hacker News dan BleepingComputer.</p>
    </a>
  </div>
</PageLayout>

<style>
  .hero {
    padding: 2.5rem;
    margin-bottom: 2rem;
  }
  .eyebrow {
    display: inline-block;
    color: var(--brand);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }
  .hero h1 {
    font-size: 2rem;
    max-width: 32rem;
  }
  .lead {
    color: var(--text-muted);
    max-width: 36rem;
    margin: 0.5rem 0 1.5rem;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .feature-card {
    margin-bottom: 0;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .feature-card:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
  }
  .feature-card h2 {
    font-size: 1rem;
    color: var(--text);
  }
  .feature-card p {
    color: var(--text-muted);
    font-size: 0.88rem;
    margin: 0;
  }
</style>
