---
import Navbar from '../components/Navbar.astro';
import { getSessionUser } from '../server/auth/session';

const db = Astro.locals.runtime.env.DB;
const token = Astro.cookies.get('session')?.value;
const user = token ? await getSessionUser(db, token) : null;
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Rekan Siber — Proactive Cyber Defense</title>
  </head>
  <body>
    <Navbar user={user} />
    <main>
      <h1>Rekan Siber</h1>
      <p>
        Cek reputasi IP, domain, hash, dan URL sebelum jadi korban phishing —
        gratis untuk publik, plus fitur lengkap untuk tim SOC.
      </p>
      <a href="/ioc-checker">Mulai cek IOC →</a>
    </main>
  </body>
</html>
