---
import AppLayout from '../layouts/AppLayout.astro';
import { getSessionUser } from '../server/auth/session';
import { listPhishingReports } from '../server/phishing/reports';

const db = Astro.locals.runtime.env.DB;
const token = Astro.cookies.get('session')?.value;
const user = token ? await getSessionUser(db, token) : null;

if (!user) {
  return Astro.redirect('/login');
}

const reports = await listPhishingReports(db);
---

<AppLayout title="Report Phishing" user={user}>
  <div class="page-header">
    <h1>Report Phishing ke Hosting Provider</h1>
    <p>
      Buat draft laporan, generate template email abuse report, lalu kirim manual lewat email
      kamu sendiri. Update status di sini setelah terkirim / selesai ditangani provider.
    </p>
  </div>

  <div class="card">
    <h2>Buat Laporan Baru</h2>
    <form id="phishing-form">
      <div class="field">
        <label for="target-domain">Domain/URL phishing</label>
        <input id="target-domain" type="text" required placeholder="contoh: phishing-bank-abc.xyz" />
      </div>
      <div class="field">
        <label for="hosting-email">Email abuse hosting provider (opsional)</label>
        <div class="email-row">
          <input id="hosting-email" type="email" placeholder="abuse@hostingprovider.com" />
          <button type="button" id="whois-btn" class="btn btn-secondary btn-sm">Isi otomatis (WHOIS)</button>
        </div>
        <p id="whois-hint" class="hint" style="margin:0.4rem 0 0;"></p>
      </div>
      <div class="field">
        <label for="notes">Catatan/bukti (opsional)</label>
        <textarea id="notes" rows="3"></textarea>
      </div>
      <button type="submit" class="btn">Buat Draft</button>
    </form>
    <p id="form-status" class="status-message" role="status"></p>
  </div>

  <div class="card">
    <h2>Daftar Laporan</h2>
    <table>
      <thead>
        <tr>
          <th>Domain</th>
          <th>Hosting Email</th>
          <th>Status</th>
          <th>Dibuat Oleh</th>
          <th>Tanggal</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        {reports.map((r) => (
          <tr>
            <td>{r.target_domain}</td>
            <td>{r.hosting_email ?? '-'}</td>
            <td><span class={`badge badge-${r.status}`}>{r.status}</span></td>
            <td>{r.reporter_name}</td>
            <td>{r.created_at.slice(0, 10)}</td>
            <td class="actions-cell">
              <button class="view-template-btn btn btn-secondary btn-sm" data-id={r.id}>Lihat Template</button>
              {r.status === 'draft' && (
                <button class="mark-status-btn btn btn-secondary btn-sm" data-id={r.id} data-status="sent">
                  Tandai Terkirim
                </button>
              )}
              {r.status === 'sent' && (
                <button class="mark-status-btn btn btn-secondary btn-sm" data-id={r.id} data-status="resolved">
                  Tandai Selesai
                </button>
              )}
              {(user.role === 'admin' || r.user_id === user.id) && (
                <button class="delete-report-btn btn btn-secondary btn-sm btn-danger" data-id={r.id} data-domain={r.target_domain}>
                  Hapus
                </button>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
    {reports.length === 0 && <p class="empty-state">Belum ada laporan.</p>}
  </div>

  <div id="template-modal" class="modal-overlay" style="display:none;">
    <div class="card modal-box">
      <h2>Template Email</h2>
      <textarea id="template-text" rows="16" readonly></textarea>
      <div class="btn-row" style="margin-top:1rem;">
        <button id="copy-template-btn" type="button" class="btn">Copy ke Clipboard</button>
        <button id="close-template-btn" type="button" class="btn btn-secondary">Tutup</button>
      </div>
    </div>
  </div>

  <style>
    .actions-cell {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .btn-sm {
      padding: 0.4rem 0.85rem;
      font-size: 0.82rem;
    }
    .btn-danger {
      color: var(--danger);
    }
    .btn-danger:hover {
      border-color: var(--danger);
    }
    .email-row {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      flex-wrap: wrap;
    }
    .email-row input {
      flex: 1;
      min-width: 220px;
      width: auto;
    }
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      z-index: 50;
    }
    .modal-box {
      width: 100%;
      max-width: 640px;
      max-height: 85vh;
      overflow-y: auto;
      margin-bottom: 0;
    }
    .modal-box textarea {
      width: 100%;
    }
  </style>

  <script>
    const form = document.getElementById('phishing-form') as HTMLFormElement;
    const formStatus = document.getElementById('form-status')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const targetDomain = (document.getElementById('target-domain') as HTMLInputElement).value;
      const hostingEmail = (document.getElementById('hosting-email') as HTMLInputElement).value;
      const notes = (document.getElementById('notes') as HTMLTextAreaElement).value;

      formStatus.textContent = 'Menyimpan...';
      const res = await fetch('/api/phishing-reports', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ target_domain: targetDomain, hosting_email: hostingEmail, notes }),
      });

      if (!res.ok) {
        const data = (await res.json().catch(() => ({}))) as { error?: string };
        formStatus.textContent = data.error ?? 'Gagal menyimpan laporan';
        return;
      }

      window.location.reload();
    });

    const templateModal = document.getElementById('template-modal') as HTMLDivElement;
    const templateText = document.getElementById('template-text') as HTMLTextAreaElement;

    document.querySelectorAll<HTMLButtonElement>('.view-template-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const res = await fetch(`/api/phishing-reports/${btn.dataset.id}/template`);
        templateText.value = await res.text();
        templateModal.style.display = 'flex';
      });
    });

    document.getElementById('close-template-btn')?.addEventListener('click', () => {
      templateModal.style.display = 'none';
    });

    templateModal.addEventListener('click', (e) => {
      if (e.target === templateModal) templateModal.style.display = 'none';
    });

    document.getElementById('copy-template-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(templateText.value);
    });

    document.querySelectorAll<HTMLButtonElement>('.mark-status-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        await fetch(`/api/phishing-reports/${btn.dataset.id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: btn.dataset.status }),
        });
        window.location.reload();
      });
    });

    // --- Hapus laporan (admin: semua, member: miliknya sendiri) ---
    document.querySelectorAll<HTMLButtonElement>('.delete-report-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm(`Hapus laporan untuk "${btn.dataset.domain}"? Tindakan ini tidak bisa dibatalkan.`)) return;

        const res = await fetch(`/api/phishing-reports/${btn.dataset.id}`, { method: 'DELETE' });
        if (!res.ok) {
          const data = (await res.json().catch(() => ({}))) as { error?: string };
          alert(data.error ?? 'Gagal menghapus laporan');
          return;
        }
        window.location.reload();
      });
    });

    // --- Auto-isi email abuse dari WHOIS (RDAP) ---
    interface AbuseLookupResult {
      domain: string;
      ip: string | null;
      registrarName: string | null;
      registrarAbuseEmails: string[];
      hostingName: string | null;
      hostingAbuseEmails: string[];
    }

    const whoisBtn = document.getElementById('whois-btn') as HTMLButtonElement;
    const whoisHint = document.getElementById('whois-hint')!;
    const hostingEmailInput = document.getElementById('hosting-email') as HTMLInputElement;
    const targetDomainInput = document.getElementById('target-domain') as HTMLInputElement;

    whoisBtn.addEventListener('click', async () => {
      const domain = targetDomainInput.value.trim();
      if (!domain) {
        whoisHint.textContent = 'Isi dulu kolom domain/URL phishing di atas.';
        return;
      }

      whoisBtn.disabled = true;
      whoisHint.textContent = 'Mencari kontak abuse via WHOIS...';
      try {
        const res = await fetch(`/api/phishing-reports/abuse-lookup?domain=${encodeURIComponent(domain)}`);
        const data = (await res.json()) as AbuseLookupResult & { error?: string };

        if (!res.ok) {
          whoisHint.textContent = data.error ?? 'Gagal melakukan lookup WHOIS';
          return;
        }

        // Email abuse hosting paling relevan untuk takedown; registrar jadi cadangan.
        const best = data.hostingAbuseEmails[0] ?? data.registrarAbuseEmails[0] ?? '';
        if (best) hostingEmailInput.value = best;

        const parts: string[] = [];
        if (data.hostingName || data.hostingAbuseEmails.length) {
          parts.push(`Hosting: ${data.hostingName ?? '?'}${data.hostingAbuseEmails[0] ? ` (${data.hostingAbuseEmails[0]})` : ''}`);
        }
        if (data.registrarName || data.registrarAbuseEmails.length) {
          parts.push(`Registrar: ${data.registrarName ?? '?'}${data.registrarAbuseEmails[0] ? ` (${data.registrarAbuseEmails[0]})` : ''}`);
        }
        if (data.ip) parts.push(`IP: ${data.ip}`);

        whoisHint.textContent = best
          ? `Terisi otomatis. ${parts.join(' | ')}`
          : `Kontak abuse tidak ditemukan otomatis -- isi manual. ${parts.join(' | ') || 'WHOIS tidak mengembalikan data.'}`;
      } catch {
        whoisHint.textContent = 'Gagal melakukan lookup WHOIS';
      } finally {
        whoisBtn.disabled = false;
      }
    });
  </script>
</AppLayout>
