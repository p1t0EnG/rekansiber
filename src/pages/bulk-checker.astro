---
import AppLayout from '../layouts/AppLayout.astro';
import IocToolsTabs from '../components/IocToolsTabs.astro';
import { getSessionUser } from '../server/auth/session';
import { MAX_BULK_ITEMS } from '../server/ioc/types';

const db = Astro.locals.runtime.env.DB;
const token = Astro.cookies.get('session')?.value;
const user = token ? await getSessionUser(db, token) : null;

if (!user) {
  return Astro.redirect('/login');
}
---

<AppLayout title="Bulk IOC Checker" user={user}>
  <div class="page-header">
    <h1>IOC Tools</h1>
    <p>Cek reputasi IOC satu per satu, secara massal, atau ekstrak dari dokumen -- pilih mode di bawah.</p>
  </div>

  <IocToolsTabs current="bulk" user={user} />

  <div class="page-header">
    <h2 style="font-size:1.15rem;">Bulk Checker</h2>
    <p>
      Tempel atau upload daftar IOC (IP, domain, hash, URL, email) satu per baris -- type
      dideteksi otomatis.
    </p>
  </div>

  <div class="callout" role="note">
    <strong class="callout-title">Cara kerja Bulk Checker — dibaca dulu ya tim</strong>
    <ul>
      <li>
        Maksimal <mark>{MAX_BULK_ITEMS} IOC per sekali cek</mark>. Kalau lebih, bagi jadi
        beberapa kali submit.
      </li>
      <li>
        IOC diproses <mark>bertahap, 5 per batch</mark> secara otomatis (biar tidak kena limit
        server) — tunggu sampai progress di bawah tombol selesai, jangan tutup halaman.
      </li>
      <li>
        Verdict <mark>"Unknown"</mark> = salah satu sumber (VirusTotal/OTX/dll) gagal diperiksa,
        <strong>bukan berarti aman</strong>. Ulangi baris itu sebelum menyimpulkan.
      </li>
    </ul>
  </div>

  <div class="card">
    <div class="field">
      <label for="bulk-input">Daftar IOC</label>
      <textarea id="bulk-input" rows="8" placeholder={'8.8.8.8\nexample.com\nhttps://evil.example/phish'}></textarea>
    </div>
    <div class="field">
      <label for="bulk-file">Atau upload file .txt/.csv</label>
      <input id="bulk-file" type="file" accept=".txt,.csv" />
    </div>
    <div class="btn-row">
      <button id="bulk-submit" type="button" class="btn">Cek Semua</button>
      <button id="bulk-export" type="button" class="btn btn-secondary" disabled>Export CSV</button>
    </div>
    <p id="bulk-status" class="status-message" role="status"></p>
  </div>

  <div class="card" id="bulk-results-card" style="display:none;">
    <table>
      <thead>
        <tr>
          <th>Value</th>
          <th>Type</th>
          <th>Verdict</th>
          <th>Detail</th>
        </tr>
      </thead>
      <tbody id="bulk-results-body"></tbody>
    </table>
  </div>

  <style>
    .callout {
      background: rgba(56, 189, 248, 0.08);
      border: 1px solid var(--border);
      border-left: 3px solid var(--brand);
      border-radius: var(--radius);
      padding: 1.1rem 1.35rem;
      margin-bottom: 1.5rem;
    }
    .callout-title {
      display: block;
      color: var(--brand-strong);
      margin-bottom: 0.5rem;
      font-size: 0.95rem;
    }
    .callout ul {
      margin: 0;
      padding-left: 1.1rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .callout li {
      font-size: 0.9rem;
      color: var(--text);
    }
    .callout mark {
      background: rgba(56, 189, 248, 0.2);
      color: var(--brand-strong);
      padding: 0.05rem 0.35rem;
      border-radius: 4px;
      font-weight: 600;
    }
  </style>

  <script>
    import { detectIocType } from '../server/ioc/validate';
    import { MAX_BULK_ITEMS } from '../server/ioc/types';
    import type { IocType, Verdict } from '../server/ioc/types';

    interface BulkResultItem {
      value: string;
      type: IocType | null;
      verdict: Verdict;
      error?: string;
      providers: { name: string; verdict: Verdict; detail: string }[];
    }

    const textarea = document.getElementById('bulk-input') as HTMLTextAreaElement;
    const fileInput = document.getElementById('bulk-file') as HTMLInputElement;
    const submitBtn = document.getElementById('bulk-submit') as HTMLButtonElement;
    const exportBtn = document.getElementById('bulk-export') as HTMLButtonElement;
    const statusEl = document.getElementById('bulk-status')!;
    const resultsCard = document.getElementById('bulk-results-card') as HTMLDivElement;
    const tbody = document.getElementById('bulk-results-body')!;

    let lastResults: BulkResultItem[] = [];

    // Hasil kiriman dari halaman IOC Extractor ("Cek di Bulk Checker")
    const prefill = sessionStorage.getItem('rekansiber:bulk-prefill');
    if (prefill) {
      sessionStorage.removeItem('rekansiber:bulk-prefill');
      textarea.value = prefill;
      const count = prefill.split('\n').filter(Boolean).length;
      statusEl.textContent =
        `${count} IOC dimuat dari IOC Extractor` +
        (count > MAX_BULK_ITEMS ? ` -- maksimal ${MAX_BULK_ITEMS} per batch, kurangi dulu sebelum cek` : '');
    }

    fileInput.addEventListener('change', async () => {
      const file = fileInput.files?.[0];
      if (!file) return;
      textarea.value = await file.text();
    });

    submitBtn.addEventListener('click', async () => {
      const lines = textarea.value
        .split('\n')
        .map((l) => l.trim())
        .filter(Boolean);

      if (lines.length === 0) {
        statusEl.textContent = 'Masukkan minimal 1 IOC';
        return;
      }
      if (lines.length > MAX_BULK_ITEMS) {
        statusEl.textContent = `Maksimal ${MAX_BULK_ITEMS} IOC sekaligus (kamu memasukkan ${lines.length})`;
        return;
      }

      const items: { value: string; type: IocType }[] = [];
      let skipped = 0;
      for (const line of lines) {
        const type = detectIocType(line);
        if (!type) {
          skipped++;
          continue;
        }
        items.push({ value: line, type });
      }

      if (items.length === 0) {
        statusEl.textContent = 'Tidak ada IOC dengan format valid yang terdeteksi';
        return;
      }

      // Dikirim per-chunk kecil, bukan sekaligus. Satu invocation Cloudflare
      // Workers dibatasi ~50 subrequest; tiap IOC butuh 2-3 panggilan provider,
      // jadi mengirim banyak IOC dalam satu request bikin sisa IOC gagal
      // ("Gagal menghubungi VT/OTX") setelah limit tercapai. Dengan chunk 5,
      // tiap request maksimal ~15 subrequest -- jauh di bawah batas.
      const CHUNK_SIZE = 5;

      submitBtn.disabled = true;
      exportBtn.disabled = true;
      lastResults = [];
      tbody.innerHTML = '';
      resultsCard.style.display = 'block';

      let hadFailure = false;
      try {
        for (let start = 0; start < items.length; start += CHUNK_SIZE) {
          const chunk = items.slice(start, start + CHUNK_SIZE);
          const from = start + 1;
          const to = Math.min(start + chunk.length, items.length);
          statusEl.textContent = `Memeriksa ${from}-${to} dari ${items.length} IOC...`;

          try {
            const res = await fetch('/api/ioc/bulk-check', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ items: chunk }),
            });

            if (!res.ok) {
              const data = (await res.json().catch(() => ({}))) as { error?: string };
              hadFailure = true;
              for (const item of chunk) {
                lastResults.push({
                  value: item.value,
                  type: item.type,
                  verdict: 'unknown',
                  error: data.error ?? `Gagal memeriksa (HTTP ${res.status})`,
                  providers: [],
                });
              }
            } else {
              const data = (await res.json()) as { results: BulkResultItem[] };
              lastResults.push(...data.results);
            }
          } catch {
            // Kegagalan jaringan pada satu chunk tidak menghentikan chunk lain
            hadFailure = true;
            for (const item of chunk) {
              lastResults.push({
                value: item.value,
                type: item.type,
                verdict: 'unknown',
                error: 'Gagal menghubungi server',
                providers: [],
              });
            }
          }

          renderResults(lastResults);
        }

        statusEl.textContent =
          `Selesai: ${lastResults.length} IOC diperiksa` +
          (skipped ? `, ${skipped} baris dilewati (format tidak dikenali)` : '') +
          (hadFailure ? '. Sebagian gagal diperiksa -- lihat kolom Detail, lalu ulangi baris tersebut.' : '');
        exportBtn.disabled = lastResults.length === 0;
      } finally {
        submitBtn.disabled = false;
      }
    });

    function renderResults(results: BulkResultItem[]) {
      tbody.innerHTML = '';
      for (const r of results) {
        const detail = r.error ?? r.providers.map((p) => `${p.name}: ${p.detail}`).join(' | ');
        const tr = document.createElement('tr');

        const valueTd = document.createElement('td');
        valueTd.textContent = r.value;

        const typeTd = document.createElement('td');
        typeTd.textContent = r.type ?? '-';

        const verdictTd = document.createElement('td');
        const badge = document.createElement('span');
        badge.className = `badge badge-${r.verdict}`;
        badge.textContent = r.verdict;
        verdictTd.appendChild(badge);

        const detailTd = document.createElement('td');
        detailTd.textContent = detail;

        tr.appendChild(valueTd);
        tr.appendChild(typeTd);
        tr.appendChild(verdictTd);
        tr.appendChild(detailTd);
        tbody.appendChild(tr);
      }
      resultsCard.style.display = results.length ? 'block' : 'none';
    }

    function csvEscape(value: string): string {
      if (/[",\n\r]/.test(value)) {
        return `"${value.replace(/"/g, '""')}"`;
      }
      return value;
    }

    exportBtn.addEventListener('click', () => {
      if (lastResults.length === 0) return;

      const header = ['value', 'type', 'verdict', 'detail'];
      const rows = lastResults.map((r) => [
        r.value,
        r.type ?? '',
        r.verdict,
        r.error ?? r.providers.map((p) => `${p.name}: ${p.detail}`).join(' | '),
      ]);
      const csv = [header, ...rows].map((row) => row.map(csvEscape).join(',')).join('\r\n');

      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `ioc-bulk-check-${new Date().toISOString().slice(0, 10)}.csv`;
      a.click();
      URL.revokeObjectURL(url);
    });
  </script>
</AppLayout>
