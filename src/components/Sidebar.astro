---
import type { SessionUser } from '../server/auth/session';

interface Props {
  user: SessionUser | null;
}
const { user } = Astro.props;
const role = user?.role ?? 'member';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? currentPath === '/' : currentPath.startsWith(href));

const icons: Record<string, string> = {
  dashboard: `<rect x="3" y="13" width="7" height="8" rx="1.5"/><rect x="14" y="8" width="7" height="13" rx="1.5"/><rect x="3" y="3" width="7" height="6" rx="1.5"/>`,
  bulk: `<line x1="4" y1="6" x2="14" y2="6"/><line x1="4" y1="12" x2="14" y2="12"/><line x1="4" y1="18" x2="14" y2="18"/><path d="M18 4.3l1.4 1.4L22.5 3"/><path d="M18 10.3l1.4 1.4L22.5 9"/><path d="M18 16.3l1.4 1.4L22.5 15"/>`,
  phishing: `<path d="M3 6.5h18v11H3z"/><path d="M3 6.5l9 6.5 9-6.5"/><line x1="19" y1="14.6" x2="19" y2="16.3" stroke-width="2"/><circle cx="19" cy="17.6" r="0.6" fill="currentColor" stroke="none"/>`,
  report: `<path d="M6 2.5h9l4 4v15H6z"/><path d="M15 2.5v4h4"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="15" y2="16"/><line x1="9" y1="20" x2="12.5" y2="20"/>`,
  extract: `<path d="M6 2.5h9l4 4v15H6z"/><path d="M15 2.5v4h4"/><circle cx="11" cy="12.5" r="2.8"/><line x1="13.1" y1="14.6" x2="15.8" y2="17.3"/>`,
  ransom: `<circle cx="12" cy="12" r="8"/><line x1="12" y1="2.5" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="21.5"/><line x1="2.5" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="21.5" y2="12"/><circle cx="12" cy="12" r="1.3" fill="currentColor" stroke="none"/>`,
  logout: `<path d="M9 4H5a1 1 0 00-1 1v14a1 1 0 001 1h4"/><path d="M15 16l4-4-4-4"/><line x1="19" y1="12" x2="9" y2="12"/>`,
  home: `<path d="M3 12l9-8 9 8"/><path d="M5 10v10h14V10"/>`,
  search: `<circle cx="10.5" cy="10.5" r="6.5"/><line x1="19" y1="19" x2="15.2" y2="15.2"/>`,
  news: `<path d="M4 4h13v15a2 2 0 002 2H6a2 2 0 01-2-2V4z"/><path d="M17 4h3v13a2 2 0 01-2 2"/><line x1="7" y1="8" x2="14" y2="8"/><line x1="7" y1="11.5" x2="14" y2="11.5"/><line x1="7" y1="15" x2="11" y2="15"/>`,
};

const teamLinks = [
  { href: '/dashboard', label: 'Dashboard', icon: 'dashboard', adminOnly: false },
  { href: '/bulk-checker', label: 'Bulk Checker', icon: 'bulk', adminOnly: false },
  { href: '/ioc-extractor', label: 'IOC Extractor', icon: 'extract', adminOnly: false },
  { href: '/phishing-reports', label: 'Phishing Report', icon: 'phishing', adminOnly: false },
  { href: '/reports', label: 'Report Bulanan', icon: 'report', adminOnly: true },
].filter((link) => !link.adminOnly || role === 'admin');

const publicLinks = [
  { href: '/', label: 'Beranda', icon: 'home' },
  { href: '/ioc-checker', label: 'IOC Checker', icon: 'search' },
  { href: '/news', label: 'Berita', icon: 'news' },
  { href: '/ransomware-watch', label: 'Ransomware Watch', icon: 'ransom' },
];

const initial = (user?.full_name ?? '?').trim().slice(0, 1).toUpperCase();
---

<aside class="sidebar">
  <a href="/" class="sidebar-brand">
    <span class="mark">
      <svg viewBox="0 0 100 100" width="16" height="16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M50 19 L74 28 L74 47 C74 63 63 75 50 81 C37 75 26 63 26 47 L26 28 Z" stroke="currentColor" stroke-width="7" stroke-linejoin="round"/>
        <path d="M40 40 L59 43 L57 62 L46 62 Z" stroke="currentColor" stroke-width="4" stroke-linejoin="round" opacity="0.6"/>
        <circle cx="40" cy="40" r="5.5" fill="currentColor"/>
        <circle cx="59" cy="43" r="5.5" fill="currentColor"/>
        <circle cx="57" cy="62" r="5.5" fill="currentColor"/>
        <circle cx="46" cy="62" r="5.5" fill="currentColor"/>
      </svg>
    </span>
    <span class="word">Rekan Siber</span>
  </a>

  <nav class="sidebar-nav">
    {teamLinks.map((link) => (
      <a href={link.href} class="sidebar-link" class:list={{ active: isActive(link.href) }}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[link.icon]} />
        <span>{link.label}</span>
      </a>
    ))}

    <div class="sidebar-divider" role="separator"></div>

    {publicLinks.map((link) => (
      <a href={link.href} class="sidebar-link" class:list={{ active: isActive(link.href) }}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[link.icon]} />
        <span>{link.label}</span>
      </a>
    ))}
  </nav>

  <div class="sidebar-footer">
    <a
      href="/profile"
      class="sidebar-user"
      class:list={{ active: isActive('/profile') }}
      title="Buka Profile (info akun & ganti password)"
    >
      <span class="avatar">{initial}</span>
      <span class="meta">
        <span class="name">{user?.full_name}</span>
        <span class="role">{user?.role}</span>
      </span>
    </a>
    <button id="sidebar-logout" type="button" class="sidebar-link sidebar-logout-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons.logout} />
      <span>Logout</span>
    </button>
  </div>
</aside>

<style>
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 68px;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 1rem 0 0;
    overflow: hidden;
    z-index: 40;
    transition: width 0.18s ease;
  }
  .sidebar:hover,
  .sidebar:focus-within {
    width: 236px;
    box-shadow: var(--shadow);
  }

  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0 1.16rem 1.1rem;
    margin-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    white-space: nowrap;
  }
  .sidebar-brand .mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    border-radius: 7px;
    background: linear-gradient(135deg, var(--brand), #0ea5e9);
    color: #04121a;
  }
  .sidebar-brand .word {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
    opacity: 0;
    transition: opacity 0.12s ease;
  }
  .sidebar:hover .sidebar-brand .word,
  .sidebar:focus-within .sidebar-brand .word {
    opacity: 1;
  }

  .sidebar-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.6rem 0.66rem;
    overflow-y: auto;
    overflow-x: hidden;
  }

  .sidebar-divider {
    height: 1px;
    background: var(--border);
    margin: 0.5rem 0.4rem;
    flex-shrink: 0;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.6rem 0.62rem;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    text-decoration: none;
    white-space: nowrap;
    font-size: 0.88rem;
    font-weight: 500;
    font-family: inherit;
    background: none;
    border: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
    flex-shrink: 0;
  }
  .sidebar-link svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .sidebar-link span {
    opacity: 0;
    transition: opacity 0.1s ease;
  }
  .sidebar:hover .sidebar-link span,
  .sidebar:focus-within .sidebar-link span {
    opacity: 1;
  }
  .sidebar-link:hover {
    background: var(--surface-2);
    color: var(--text);
  }
  .sidebar-link.active {
    background: rgba(56, 189, 248, 0.12);
    color: var(--brand);
  }

  .sidebar-footer {
    border-top: 1px solid var(--border);
    padding: 0.75rem 0.66rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex-shrink: 0;
  }
  .sidebar-user {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.45rem 0.62rem;
    margin-bottom: 0.2rem;
    white-space: nowrap;
    text-decoration: none;
    border-radius: var(--radius-sm);
  }
  .sidebar-user:hover {
    background: var(--surface-2);
  }
  .sidebar-user.active {
    background: rgba(56, 189, 248, 0.12);
  }
  .sidebar-user.active .name {
    color: var(--brand);
  }
  .sidebar-user .avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--surface-2);
    border: 1px solid var(--border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text);
    flex-shrink: 0;
  }
  .sidebar-user .meta {
    display: flex;
    flex-direction: column;
    opacity: 0;
    overflow: hidden;
    transition: opacity 0.1s ease;
  }
  .sidebar:hover .sidebar-user .meta,
  .sidebar:focus-within .sidebar-user .meta {
    opacity: 1;
  }
  .sidebar-user .name {
    font-size: 0.83rem;
    color: var(--text);
    font-weight: 600;
  }
  .sidebar-user .role {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: capitalize;
  }
</style>

<script>
  document.getElementById('sidebar-logout')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/login';
  });
</script>
