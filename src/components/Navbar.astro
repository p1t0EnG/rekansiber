---
interface Props {
  user?: { full_name: string; role?: 'admin' | 'member' } | null;
}
const { user = null } = Astro.props;

const publicLinks = [
  { href: '/', label: 'Home' },
  { href: '/ioc-checker', label: 'IOC Checker' },
  { href: '/news', label: 'Berita' },
  { href: '/ransomware-watch', label: 'Ransomware Watch' },
];

const teamLinks = [
  { href: '/dashboard', label: 'Dashboard', adminOnly: false },
  { href: '/bulk-checker', label: 'Bulk Checker', adminOnly: false },
  { href: '/phishing-reports', label: 'Phishing Report', adminOnly: false },
  { href: '/reports', label: 'Report', adminOnly: true },
  { href: '/profile', label: 'Profile', adminOnly: false },
].filter((link) => !link.adminOnly || user?.role === 'admin');

const currentPath = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? currentPath === '/' : currentPath.startsWith(href));
---

<nav class="navbar">
  <div class="navbar-inner">
    <a href="/" class="brand">
      <span class="brand-mark">
        <svg viewBox="0 0 100 100" width="16" height="16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M50 19 L74 28 L74 47 C74 63 63 75 50 81 C37 75 26 63 26 47 L26 28 Z" stroke="currentColor" stroke-width="7" stroke-linejoin="round"/>
          <path d="M40 40 L59 43 L57 62 L46 62 Z" stroke="currentColor" stroke-width="4" stroke-linejoin="round" opacity="0.6"/>
          <circle cx="40" cy="40" r="5.5" fill="currentColor"/>
          <circle cx="59" cy="43" r="5.5" fill="currentColor"/>
          <circle cx="57" cy="62" r="5.5" fill="currentColor"/>
          <circle cx="46" cy="62" r="5.5" fill="currentColor"/>
        </svg>
      </span>
      Rekan Siber
    </a>
    <div class="links">
      {publicLinks.map((link) => (
        <a href={link.href} class:list={{ active: isActive(link.href) }}>{link.label}</a>
      ))}
      {user && (
        <>
          <span class="divider" aria-hidden="true"></span>
          {teamLinks.map((link) => (
            <a href={link.href} class:list={{ active: isActive(link.href) }}>{link.label}</a>
          ))}
        </>
      )}
    </div>
    <div class="session">
      {user ? (
        <>
          <span class="user-pill">{user.full_name}</span>
          <button id="logout-btn" type="button" class="btn btn-secondary btn-sm">Logout</button>
        </>
      ) : (
        <a href="/login" class="btn btn-secondary btn-sm">Login</a>
      )}
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(11, 13, 18, 0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .navbar-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0.9rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    color: var(--text);
    white-space: nowrap;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 7px;
    background: linear-gradient(135deg, var(--brand), #0ea5e9);
    color: #04121a;
  }
  .links {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    flex-wrap: wrap;
    flex: 1;
  }
  .links a {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.88rem;
    font-weight: 500;
    transition: color 0.15s ease;
  }
  .links a:hover {
    color: var(--text);
  }
  .links a.active {
    color: var(--brand);
  }
  .divider {
    width: 1px;
    height: 1.1rem;
    background: var(--border);
  }
  .session {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .user-pill {
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .btn-sm {
    padding: 0.4rem 0.85rem;
    font-size: 0.82rem;
  }
</style>

<script>
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/login';
  });
</script>
