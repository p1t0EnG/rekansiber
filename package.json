{
  "name": "rekansiber",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist",
    "deploy": "astro build && wrangler pages deploy ./dist --project-name=rekansiber",
    "db:migrate:local": "wrangler d1 execute rekansiber-db --local --file=./db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute rekansiber-db --remote --file=./db/schema.sql",
    "db:studio:local": "wrangler d1 execute rekansiber-db --local --command \"SELECT name FROM sqlite_master WHERE type='table';\"",
    "user:create": "node scripts/create-user.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "astro": "^5.1.0",
    "hono": "^4.6.14",
    "pdf-lib": "^1.17.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^5.20260712.1",
    "typescript": "^5.7.2",
    "wrangler": "^4.110.0"
  }
}
